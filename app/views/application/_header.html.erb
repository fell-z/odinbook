<header>
  <h1>OdinBook</h1>

  <% if user_signed_in? %>
    <nav id="header-nav">
      <ul>
        <li>
          <%= link_to "New Post", new_post_path %>
        </li>

        <li>
          <%= link_to "Recent Posts", posts_path %>
        </li>

        <li>
          <%= link_to "Users", users_path %>
        </li>

        <li>
          <%= link_to "Follow Requests", follow_requests_path %>
        </li>

        <li>
          <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete } %>
        </li>

        <% unless current_page?(user_profile_path(current_user)) %>
          <li class="user-avatar">
            <%= avatar_with_fallback(current_user, size: 48) %>
          </li>
        <% end %>
      </ul>
    </nav>
  <% end %>
</header>
