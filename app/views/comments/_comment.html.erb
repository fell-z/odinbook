<article id="comment_<%= comment.id %>">
  <section class="author-info">
    <div class="author-avatar">
      <%= image_tag "default-user.svg", alt: "user avatar", size: 32 %>
    </div>

    <div class="author-name">
      <%= comment.user.name %>
    </div>
  </section>

  <section class="comment-body">
    <p>
      <%= comment.body %>
    </p>
  </section>

  <% if current_user == comment.user %>
    <section class="comment-actions">
      <div class="comment-action-delete">
        <%= link_to "Delete Comment", comment, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
      </div>
    </section>
  <% end %>
</article>
